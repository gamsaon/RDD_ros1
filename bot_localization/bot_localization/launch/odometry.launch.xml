<launch>
  <!-- Mode option -->
  <arg name="odom"                default="true"/>
  <arg name="imu"                 default="true"/>
  <arg name="vo"                  default="false"/>
  <arg name="odom_switch_used"    default="false"/>

    <!-- IMU Driver -->
  	<!-- <param name="m_bSingle_TF_option" type="bool" value="true" /> false -->
  <node pkg="mi_ros" type="mi_driver_node" name="mi_driver_node" output="screen">
      <param name="port" value="/dev/USB_IMU" />
      <param name="frame_id" value="imu_link" />
  </node>

	<!-- Wheel Odometry Publisher -->
	<!-- Subscribe: /right_ticks, /left_ticks, /initial_2d -->
	<!-- Publish: /odom_data_euler, /odom_data_quat -->
	<node pkg="localization_data" type="ekf_odom_pub" name="ekf_odom_pub"/>

	<!-- Subscribe: /initialpose, /move_base_simple/goal -->
	<!-- Publish: /bot_initialpose, /goal_2d -->
	<node pkg="localization_data" type="rviz_click_to_2d" name="rviz_click_to_2d"/>

  
  <remap from="odom" to="odom_data_quat" />
  <remap from="imu_data" to="imu/data" />
  <node pkg="robot_pose_ekf" type="robot_pose_ekf" name="robot_pose_ekf" output="screen">
    <param name="output_frame"          value="odom"/>
    <param name="base_footprint_frame"  value="base_footprint"/>

    <!-- <param name="freq"                  value="10.0"/> -->
    <param name="freq"                  value="30.0"/>
    <param name="sensor_timeout"        value="1.0"/> 
    <param name="odom_used"             value="$(arg odom)"/>
    <param name="imu_used"              value="$(arg imu)"/>
    <param name="vo_used"               value="$(arg vo)"/>
    <param name="debug"                 value="false"/>
    <param name="gps_used"              value="false"/>
    <param name="self_diagnose" value="false"/>

    <param name="odom_switch_used"      value="$(arg odom_switch_used)"/>

    <!-- <remap from="odom"                  to="odom" /> -->
    <!-- <remap from="odom_combined"         to="odom_combined" /> -->
    <!-- <remap from="motor"                 to="motor_status" /> -->
  </node>

</launch>

