<launch>
  <arg name="resolution" default="0.02"/>

  <node name="cartographer_node" pkg="cartographer_ros"
      type="cartographer_node" args="
           -configuration_directory $(find bot_slam)/config
           -configuration_basename drawing_2d.lua"
      output="screen">
    <remap from="scan" to="scan"/>
    <remap from="odom" to="odom_data_quat"/>
    <!-- <remap from="scan" to="scan_localization"/> -->
  </node>

  <node name="cartographer_occupancy_grid_node" pkg="cartographer_ros" type="cartographer_occupancy_grid_node">
    <param name="resolution" value="$(arg resolution)"/>
  </node>

  <!-- <node name="cartographer_occupancy_grid_node" pkg="cartographer_ros"
      type="cartographer_occupancy_grid_node" args="-resolution 0.05">
  </node> -->

</launch>
