<launch>

  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <!-- <arg name="odom_topic" default="odom" /> -->
  <arg name="odom_topic" default="odom_data_quat" />
  <arg name="move_forward_only" default="false"/>


  <!-- move_base -->
  <node pkg="move_base" type="move_base" respawn="true" name="move_base" output="screen">

    <!--base planner-->
    <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS" />
    <param name="map_update_frequency" value="5.0"/>

    <!-- costmap params -->
    <rosparam file="$(find bot_parameters)/navigation/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find bot_parameters)/navigation/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find bot_parameters)/navigation/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find bot_parameters)/navigation/local_costmap_params.yaml" command="load" />

    <!-- lo9cal params -->
    <rosparam file="$(find bot_parameters)/navigation/dwa_local_planner_params.yaml" command="load"/>

    <!-- move_base params -->
    <rosparam file="$(find bot_parameters)/navigation/move_base_params.yaml" command="load" />

    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
    <param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)" />    

  </node>


</launch>


